# [database]
FORGEJO__database__DB_TYPE=postgres
FORGEJO__database__HOST=forgejo-postgres:5432
FORGEJO__database__NAME=forgejo
FORGEJO__database__PASSWD=<password>
FORGEJO__database__USER=forgejo

# [security]
FORGEJO__security__INSTALL_LOCK=true
FORGEJO__security__MIN_PASSWORD_LENGTH=8
FORGEJO__security__PASSWORD_COMPLEXITY=lower
FORGEJO__security__SECRET_KEY=<generate with: openssl rand -base64 32>

# [server]
FORGEJO__server__DOMAIN=forgejo.example.com
FORGEJO__server__LFS_START_SERVER=true
FORGEJO__server__ROOT_URL=https://forgejo.example.com
FORGEJO__server__SSH_DOMAIN=forgejo.example.com
FORGEJO__server__SSH_PORT=2222
FORGEJO__server__START_SSH_SERVER=true

# [service]
FORGEJO__service__DEFAULT_ALLOW_CREATE_ORGANIZATION=false
FORGEJO__service__DEFAULT_KEEP_EMAIL_PRIVATE=true
FORGEJO__service__DEFAULT_ORG_VISIBILITY=private
FORGEJO__service__DISABLE_REGISTRATION=true
FORGEJO__service__NO_REPLY_ADDRESS=noreply.example.com
FORGEJO__service__REQUIRE_SIGNIN_VIEW=true
FORGEJO__service__SHOW_REGISTRATION_BUTTON=false

# [webhook]
FORGEJO__webhook__ALLOWED_HOST_LIST=loopback,private,*.example.com

# [repository.signing]
# Generate key pair inside container: ssh-keygen -t ed25519 -f /etc/gitea/signing -N ''
FORGEJO__repository.signing__CRUD_ACTIONS=pubkey
FORGEJO__repository.signing__FORMAT=ssh
FORGEJO__repository.signing__INITIAL_COMMIT=pubkey
FORGEJO__repository.signing__MERGES=pubkey
FORGEJO__repository.signing__SIGNING_EMAIL=<email>
FORGEJO__repository.signing__SIGNING_KEY=/etc/gitea/signing.pub
FORGEJO__repository.signing__SIGNING_NAME=<username>
FORGEJO__repository.signing__WIKI=pubkey

# [repository.upload]
FORGEJO__repository.upload__FILE_MAX_SIZE=4095
FORGEJO__repository.upload__MAX_FILES=20
